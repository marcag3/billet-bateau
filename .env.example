# Copy to .env — see README § Configuration for all variables and defaults.
# Generate key: php artisan key:generate

APP_KEY=

DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=password

# RustFS (compose service). Defaults match RUSTFS_ACCESS_KEY / RUSTFS_SECRET_KEY in compose.yaml.
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=app
# Path-style public object URL base (bucket name is the first path segment).
AWS_URL=http://localhost:9000/app
# Browser-facing S3 API endpoint for presigned PUT URLs.
AWS_ENDPOINT_PUBLIC=http://localhost:9000
