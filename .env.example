# Copy to .env — see README § Configuration for all variables and defaults.
# Generate key: php artisan key:generate

APP_KEY=

DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=password

# Garage (--default-bucket) requires access key id length >= 8.
AWS_ACCESS_KEY_ID=localdev_access_key
AWS_SECRET_ACCESS_KEY=localdev_secret_key_change_me_in_production
# Browser-facing public object URL base (Garage s3_web, bucket as subdomain).
AWS_URL=http://app.web.garage.localhost:8900
# Browser-facing S3 API endpoint for presigned PUT URLs.
AWS_ENDPOINT_PUBLIC=http://localhost:9000
