APP_NAME="La Route de Champlain"
APP_KEY=
APP_DEBUG=true
APP_ENV=local
APP_URL=http://localhost
ASSET_URL=http://localhost
SANCTUM_STATEFUL_DOMAINS=http://localhost:8080/

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
FORWARD_DB_PORT=3306
DB_DATABASE=lrdc
DB_USERNAME=lrdc
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SCOUT_QUEUE=true
SCOUT_DRIVER=tntsearch
TNTSEARCH_FUZZINESS=true

TELESCOPE_ENABLED=true

SQUARE_ACCESS_TOKEN=
