APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=password

# Local tests: phpunit.xml targets DB_DATABASE=testing on this host. Create that database and run
# CREATE EXTENSION postgis; there (compose uses postgis/postgis so the main DB has PostGIS; new DBs need the extension).

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_REDIS_CONNECTION=default

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,::1

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sail dev: Mailpit SMTP (dashboard http://localhost:8025)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Garage (--default-bucket) requires access key id length >= 8; use the same values in .env for Laravel.
AWS_ACCESS_KEY_ID=localdev_access_key
AWS_SECRET_ACCESS_KEY=localdev_secret_key_change_me_in_production
AWS_DEFAULT_REGION=garage
AWS_BUCKET=app
AWS_ENDPOINT=http://garage:3900    # Laravel SDK
# Browser-facing public object URL base via Garage s3_web (bucket as subdomain).
AWS_URL=http://app.web.garage.localhost:8900
# Browser-facing S3 API endpoint used for presigned PUT URLs.
AWS_ENDPOINT_PUBLIC=http://localhost:9000    # browser-facing (presigned URL host)
# Comma-separated allowed origins for direct S3 PUT/GET from the SPA (run `php artisan storage:configure` after deploy).
AWS_CORS_ALLOWED_ORIGINS=*
AWS_USE_PATH_STYLE_ENDPOINT=true


FORWARD_POWERSYNC_PORT=6080
POWERSYNC_PUBLIC_URL=http://localhost:6080
POWERSYNC_JWT_SECRET=powersync-local-poc-secret-32_bytes!
POWERSYNC_DATA_SOURCE_URI=postgresql://${DB_USERNAME}:${DB_PASSWORD}@pgsql:5432/${DB_DATABASE}?sslmode=disable
POWERSYNC_STORAGE_SOURCE_URI=postgresql://${DB_USERNAME}:${DB_PASSWORD}@pgsql:5432/powersync_storage?sslmode=disable

VITE_APP_NAME="${APP_NAME}"
