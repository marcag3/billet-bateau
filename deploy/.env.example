# Copy to deploy/.env on the server. For full Laravel variables see the repo root .env.example.
#
# Deploy:
#   cd deploy
#   docker compose pull
#   docker compose up -d
#   docker compose exec production php artisan migrate --force
#   docker compose exec production php artisan storage:configure --no-interaction

PRODUCTION_IMAGE=ghcr.io/owner/repo:master

APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=app.example.com

REDIS_HOST=redis
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=garage
AWS_BUCKET=app
AWS_ENDPOINT=http://garage:3900
AWS_URL=https://app.web.example.com
AWS_ENDPOINT_PUBLIC=https://s3.example.com
AWS_CORS_ALLOWED_ORIGINS=https://app.example.com
AWS_USE_PATH_STYLE_ENDPOINT=true

POWERSYNC_PUBLIC_URL=https://sync.example.com
POWERSYNC_JWT_SECRET=
POWERSYNC_DATA_SOURCE_URI=postgresql://${DB_USERNAME}:${DB_PASSWORD}@pgsql:5432/${DB_DATABASE}?sslmode=disable
POWERSYNC_STORAGE_SOURCE_URI=postgresql://${DB_USERNAME}:${DB_PASSWORD}@pgsql:5432/powersync_storage?sslmode=disable

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
