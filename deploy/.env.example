# Copy to deploy/.env on the server. See README § Configuration for all variables.
#
# Deploy:
#   cd deploy
#   docker compose pull
#   docker compose up -d
#   docker compose exec production php artisan migrate --force
#   (Garage CORS is applied automatically on production container start via deploy/entrypoint.d/60-startup.sh)

PRODUCTION_IMAGE=ghcr.io/owner/repo:master
POWERSYNC_IMAGE=ghcr.io/owner/repo-powersync:master

APP_KEY=
APP_URL=https://app.example.com

DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_URL=https://app.web.example.com
AWS_ENDPOINT_PUBLIC=https://s3.example.com
AWS_CORS_ALLOWED_ORIGINS=https://app.example.com

POWERSYNC_PUBLIC_URL=https://sync.example.com
POWERSYNC_JWT_SECRET=

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="billet@example.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

SENTRY_LARAVEL_DSN=
