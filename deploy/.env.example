# Copy to deploy/.env on the server. See README § Configuration for all variables.
#
# Deploy:
#   cd deploy
#   docker compose pull
#   docker compose up -d
#   docker compose exec production php artisan migrate --force
#
# Object storage: Cloudflare R2. Create a bucket, enable public access (custom domain or r2.dev),
# and set CORS in the R2 bucket settings (GET, HEAD, PUT; expose ETag; your SPA origin).

PRODUCTION_IMAGE=ghcr.io/owner/repo:master

APP_KEY=
APP_URL=https://app.example.com

DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=

# Cloudflare R2 — create an API token with Object Read & Write on the bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=app
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_URL=https://media.example.com
AWS_ENDPOINT_PUBLIC=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

POWERSYNC_PUBLIC_URL=https://sync.example.com
POWERSYNC_JWT_SECRET=

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="billet@example.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

SENTRY_LARAVEL_DSN=

# Google OAuth (optional). Redirect URI defaults to {APP_URL}/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
