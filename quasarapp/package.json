{
    "name": "quasarapp",
    "version": "3.0.0",
    "description": "Portail La Route De Champlain",
    "productName": "La Route De Champlain",
    "author": "mantoine3 <mantoine3@gmail.com>",
    "private": true,
    "scripts": {
        "lint": "eslint --ext .js,.vue ./",
        "test": "echo \"See package.json => scripts for available tests.\" && exit 0",
        "test:unit": "jest --updateSnapshot",
        "test:unit:ci": "jest --ci",
        "test:unit:coverage": "jest --coverage",
        "test:unit:watch": "jest --watch",
        "test:unit:watchAll": "jest --watchAll",
        "serve:test:coverage": "quasar serve test/jest/coverage/lcov-report/ --port 8788",
        "concurrently:dev:jest": "concurrently \"quasar dev\" \"jest --watch\"",
        "test:unit:ui": "majestic",
        "test:e2e": "cross-env E2E_TEST=true start-test \"quasar dev\" http-get://localhost:8080 \"cypress open\"",
        "test:e2e:ci": "cross-env E2E_TEST=true start-test \"quasar dev\" http-get://localhost:8080 \"cypress run\"",
        "serve:test:lighthouse": "quasar serve test/lighthouse/reports/ --port 8789",
        "audit:snyk": "snyk test --json > ./test/audits/snyk.json",
        "audit:node_modules": "yarn audit --json > ./test/audits/node_modules_audit.json",
        "audit:licenses": "nlf --summary detail > ./test/audits/licenses.txt",
        "audit:lighthouse": "lighthouse http://localhost:3000 view --output-path=./test/lighthouse/reports/index.html --config-path=./test/lighthouse/configs/full-config.js"
    },
    "dependencies": {
        "@intlify/vue-i18n-loader": "^4.0.1",
        "@quasar/extras": "^1.12.4",
        "@quasar/quasar-ui-qcalendar": "^4.0.0-beta.12",
        "@vue/devtools": "*",
        "@vuelidate/core": "^2.0.0-alpha.21",
        "@vuelidate/validators": "^2.0.0-alpha.18",
        "axios": "^0.24.0",
        "core-js": "^3.6.5",
        "dayjs": "^1.10.7",
        "dotenv": "^16.0.0",
        "eslint-plugin-vue": "^8.2.0",
        "pinia": "^2.0.6",
        "quasar": "^2.5.2",
        "vue": "^3.2.29",
        "vue-i18n": "^9.1.6",
        "vue-router": "^4.0.12",
        "vue-template-compiler": "^2.6.14",
        "vue-the-mask": "^0.11.1",
        "webpack": "^5.104.1",
        "yaml-loader": "^0.6.0"
    },
    "devDependencies": {
        "@babel/core": "^7.14.5",
        "@babel/eslint-parser": "^7.14.5",
        "@babel/eslint-plugin": "^7.13.16",
        "@quasar/app": "^3.3.2",
        "babel-eslint": "^10.0.1",
        "eslint": "^8.4.1",
        "eslint-config-prettier": "^8.1.0",
        "eslint-webpack-plugin": "^3.1.1",
        "majestic": "^1.2.24",
        "wallaby-vue-compiler": "^1.0.3"
    },
    "browserslist": [
        "defaults,iOS >= 12,Safari >= 12"
    ],
    "engines": {
        "node": ">= 12.22.1",
        "npm": ">= 6.13.4",
        "yarn": ">= 1.21.1"
    },
    "main": "index.js",
    "license": "MIT"
}
