{
    "name": "Billet Bateau",
    "dockerComposeFile": ["../compose.yaml", "../compose.dev.yaml"],
    "service": "laravel.test",
    "workspaceFolder": "/var/www/html",
    "remoteUser": "sail",
    "runServices": [
        "pgsql",
        "redis",
        "powersync",
        "garage",
        "mailpit",
        "gotenberg",
        "laravel.test"
    ],
    "forwardPorts": [80, 5173, 5432, 6080, 8025],
    "portsAttributes": {
        "80": { "label": "Laravel" },
        "5173": { "label": "Vite" },
        "5432": { "label": "PostgreSQL" },
        "6080": { "label": "PowerSync" },
        "8025": { "label": "Mailpit" }
    },
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "postStartCommand": "php artisan migrate --force --no-interaction && php artisan storage:configure --no-interaction",
    "customizations": {
        "vscode": {
            "extensions": [
                "mehedidracula.php-namespace-resolver",
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "junstyle.php-cs-fixer",
                "onecentlin.laravel-extension-pack",
                "georgykurian.laravel-ide-helper",
                "esbenp.prettier-vscode",
                "wayou.vscode-todo-highlight",
                "vscode-icons-team.vscode-icons",
                "csstools.postcss",
                "jaguadoromero.vscode-php-create-class",
                "open-southeners.laravel-pint",
                "sperovita.alpinejs-syntax-highlight",
                "formulahendry.auto-close-tag",
                "formulahendry.auto-rename-tag",
                "kamikillerto.vscode-colorize",
                "vue.volar"
            ],
            "settings": {}
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/home/sail/.gitconfig,type=bind,consistency=cached"
    ]
}
