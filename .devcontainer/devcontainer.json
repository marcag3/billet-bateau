// https://aka.ms/devcontainer.json
// Node version: Docker build arg NODE_VERSION in compose.dev.yaml (default 24); see Dockerfile devtools stage.
{
    "name": "Docker",
    "dockerComposeFile": ["../compose.yaml", "../compose.dev.yaml"],
    "service": "laravel.test",
    "workspaceFolder": "/var/www/html",
    "customizations": {
        "vscode": {
            "extensions": [
                "mehedidracula.php-namespace-resolver",
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "junstyle.php-cs-fixer",
                "onecentlin.laravel-extension-pack",
                "georgykurian.laravel-ide-helper",
                "esbenp.prettier-vscode",
                "wayou.vscode-todo-highlight",
                "vscode-icons-team.vscode-icons",
                "csstools.postcss",
                "jaguadoromero.vscode-php-create-class",
                "open-southeners.laravel-pint",
                "sperovita.alpinejs-syntax-highlight",
                "formulahendry.auto-close-tag",
                "formulahendry.auto-rename-tag",
                "kamikillerto.vscode-colorize",
                "vue.volar"
            ],
            "settings": {}
        }
    },
    "remoteUser": "sail",
    "postCreateCommand": "chown -R 1000:1000 /var/www/html && npm ci",
    "forwardPorts": [5173],
    // "runServices": [],
    // "shutdownAction": "none",
    // "containerEnv": {
    //     "SSH_AUTH_SOCK": "/tmp/bitwarden-ssh-agent.sock"
    // },
    "mounts": [
    //     "source=${localEnv:HOME}/.ssh,target=/home/sail/.ssh,type=bind,consistency=cached",
        // "source=${localEnv:HOME}/.gitconfig,target=/home/sail/.gitconfig,type=bind,consistency=cached",
        // "source=${localEnv:SSH_AUTH_SOCK},target=/tmp/host-ssh-auth.sock,type=bind,consistency=cached"
    ]
}
